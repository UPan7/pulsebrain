# OpenRouter API
OPENROUTER_API_KEY=sk-or-v1-...

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:AAE...

# Multi-tenant allowlist — comma-separated list of Telegram chat_ids
# allowed to use this bot. The first id is treated as the admin
# (receives migration artifacts from legacy single-user data).
#
# Example for 3 friends:
#   TELEGRAM_CHAT_IDS=56994937,123456789,987654321
TELEGRAM_CHAT_IDS=56994937

# Legacy single-user fallback (ignored when TELEGRAM_CHAT_IDS is set).
# Kept for backward compatibility with existing deployments.
# TELEGRAM_CHAT_ID=56994937

# Schedule
CHECK_INTERVAL_MINUTES=30

# Relevance gate for auto-fetched scheduler content (1-10). Videos
# scoring below this get silently rejected. Per-channel override lives
# in each user's channels.yml as `min_relevance: <int>`.
MIN_RELEVANCE_THRESHOLD=4

# Optional
LOG_LEVEL=INFO
TRANSCRIPT_LANGUAGES=en,de,ru   # Priority order
